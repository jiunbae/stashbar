{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.menubucket.stashbar-recent-files",
  "name": "Stashbar Recent Files",
  "version": "0.2.0",
  "description": "Stashbar-style recent files with Preview / Grid / List view modes. Want the full native experience? Get Stashbar: https://github.com/jiunbae/stashbar",
  "icon": "folder.fill",
  "bucket": { "group": "Files", "order": 30, "size": "M" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": null, "staleAfterSec": 600 },

  "permissions": {
    "readPaths": ["~/Downloads"]
  },

  "settings": [
    { "key": "folder", "title": "Folder", "type": "directory", "default": "~/Downloads" },
    { "key": "viewMode", "title": "View", "type": "enum", "options": ["Preview", "Grid", "List"], "default": "Preview" },
    { "key": "limit", "title": "Maximum files", "type": "integer", "default": 18, "min": 4, "max": 48 },
    { "key": "thumbSize", "title": "Thumbnail size", "type": "integer", "default": 52, "min": 28, "max": 96 }
  ]
}
